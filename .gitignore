# macOS local state
.DS_Store

# Local databases and tool caches
*.sqlite
*.sqlite-shm
*.sqlite-wal
/.ruff_cache/

# Agent tool state — ignore everything, track only the curated config.
# Allowlist (not blocklist) so new runtime dirs can never leak in on their own.
# This is git's job: keep machine state out of history. Stow's separate job
# (keeping repo-internal paths out of $HOME) lives in .stow-local-ignore.
/.agents/

/.claude/*
!/.claude/CLAUDE.md
!/.claude/skills/

/.config/codex/*
!/.config/codex/config.toml

/.config/opencode/*
!/.config/opencode/opencode.jsonc
!/.config/opencode/command/
!/.config/opencode/tools/

/.opencode/*
!/.opencode/skills/

# Local secrets and work-environment overlays
/zshenv/init/*.secret.zsh
/zshenv/init/env.*.work.zsh
/zshenv/init/env.secrets.*.zsh
/zshenv/init/shelf/
/zshrc/init/*.secret.zsh
