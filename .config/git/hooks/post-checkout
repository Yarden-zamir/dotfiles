#!/bin/sh
#
# Link <project>/_shared into the worktree that was just checked out, then hand
# off to the repository's own hook, which core.hooksPath would otherwise shadow.

set -u

# $3 is 1 for a branch checkout (also clone and worktree add), 0 for a file
# checkout. Only a branch checkout can change what should be linked.
if [ "${3:-1}" = "1" ]; then
  worktree=$(git rev-parse --show-toplevel 2>/dev/null) || worktree=

  if [ -n "$worktree" ]; then
    project=$(dirname "$worktree")

    if [ -d "$project/.bare" ] && [ -d "$project/_shared" ]; then
      linker="${DOTFILES:-$HOME/Github/dotfiles/main}/bin/git-shared-link"
      # A checkout must never fail because linking did.
      [ -x "$linker" ] && "$linker" "$worktree" || true
    fi
  fi
fi

common_dir=$(git rev-parse --git-common-dir 2>/dev/null) || exit 0
repo_hook="$common_dir/hooks/post-checkout"

if [ -x "$repo_hook" ] && [ "$repo_hook" != "$0" ]; then
  exec "$repo_hook" "$@"
fi

exit 0
