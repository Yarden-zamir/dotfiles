#!/usr/bin/env -S uv run --script
# /// script
# requires-python = ">=3.12"
# dependencies = ["typer>=0.26.7"]
# ///

from __future__ import annotations

import os
import shutil
import subprocess
import sys
from dataclasses import dataclass
from datetime import datetime
from pathlib import Path
from typing import Annotated

import typer


@dataclass(frozen=True)
class SkippedIgnoredEntry:
    path: Path
    items: list[Path]
    is_dir: bool

    @property
    def item_count(self) -> int:
        return len(self.items)


@dataclass(frozen=True)
class StashEntry:
    oid: str
    branch: str
    subject: str


@dataclass(frozen=True)
class MigrationPlan:
    repo_root: Path
    staging_root: Path
    backup_zip: Path | None
    bare_root: Path
    shared_root: Path
    current_branch: str
    branch_worktrees: dict[str, Path]
    stash_entries: list[StashEntry]
    ignored_files: list[Path]
    skipped_ignored: list[SkippedIgnoredEntry]


def info(message: str) -> None:
    print(f"🟢 {message}", flush=True)


def warn(message: str) -> None:
    print(f"🟠 warning: {message}", file=sys.stderr, flush=True)


def fail(message: str) -> None:
    print(f"🔴 error: {message}", file=sys.stderr, flush=True)
    raise SystemExit(1)


def run_git(args: list[str], cwd: Path, *, check: bool = True) -> subprocess.CompletedProcess[str]:
    result = subprocess.run(
        ["git", *args],
        cwd=cwd,
        text=True,
        stdout=subprocess.PIPE,
        stderr=subprocess.PIPE,
        check=False,
    )
    if check and result.returncode != 0:
        command = "git " + " ".join(args)
        detail = result.stderr.strip() or result.stdout.strip() or "unknown Git failure"
        fail(f"{command} failed in {cwd}: {detail}")
    return result


def run_command(args: list[str], cwd: Path) -> None:
    result = subprocess.run(args, cwd=cwd, text=True, check=False)
    if result.returncode != 0:
        fail(f"{' '.join(args)} failed in {cwd}")


def parse_stash_branch(text: str) -> str | None:
    for prefix in ("WIP on ", "On "):
        if not text.startswith(prefix):
            continue

        rest = text[len(prefix) :]
        branch, separator, _message = rest.partition(":")
        if separator and branch.strip():
            return branch.strip()

    for marker in (": WIP on ", ": On "):
        marker_index = text.find(marker)
        if marker_index == -1:
            continue

        rest = text[marker_index + len(marker) :]
        branch, separator, _message = rest.partition(":")
        if separator and branch.strip():
            return branch.strip()

    return None


def branch_exists(repo_root: Path, branch: str) -> bool:
    result = run_git(["show-ref", "--verify", "--quiet", f"refs/heads/{branch}"], repo_root, check=False)
    return result.returncode == 0


def full_branch_dir_name(branch: str) -> str:
    name = branch.strip().strip("/").replace("/", "-")
    if not name:
        fail(f"cannot derive a worktree directory name for branch {branch!r}")
    return name


def preferred_branch_dir_name(branch: str) -> str:
    name = branch.strip().strip("/").split("/")[-1]
    if not name:
        fail(f"cannot derive a worktree directory name for branch {branch!r}")
    return name


def branch_worktree_paths(repo_root: Path, branches: list[str]) -> dict[str, Path]:
    basename_counts: dict[str, int] = {}
    for branch in branches:
        basename = preferred_branch_dir_name(branch)
        basename_counts[basename] = basename_counts.get(basename, 0) + 1

    names: dict[str, str] = {}
    used: dict[str, str] = {}
    for branch in branches:
        basename = preferred_branch_dir_name(branch)
        name = full_branch_dir_name(branch) if basename_counts[basename] > 1 else basename
        if name in used:
            fail(f"branches {used[name]!r} and {branch!r} both resolve to worktree directory {name!r}")
        used[name] = branch
        names[branch] = name

    return {branch: repo_root / name for branch, name in names.items()}


def repo_root_from_cwd(cwd: Path) -> Path:
    result = run_git(["rev-parse", "--show-toplevel"], cwd)
    return Path(result.stdout.strip()).resolve()


def git_dir_for_repo(repo_root: Path) -> Path:
    result = run_git(["rev-parse", "--git-dir"], repo_root)
    raw_path = Path(result.stdout.strip())
    if raw_path.is_absolute():
        return raw_path
    return repo_root / raw_path


def current_branch(repo_root: Path) -> str:
    result = run_git(["branch", "--show-current"], repo_root)
    branch = result.stdout.strip()
    if not branch:
        fail("refusing to migrate a detached HEAD checkout")
    return branch


def ensure_repo_can_migrate(repo_root: Path) -> None:
    bare_result = run_git(["rev-parse", "--is-bare-repository"], repo_root)
    if bare_result.stdout.strip() == "true":
        fail("refusing to migrate a bare repository")

    git_dir = git_dir_for_repo(repo_root)
    if not git_dir.is_dir():
        fail("refusing to migrate a linked worktree or repository with non-directory .git metadata")

    worktree_result = run_git(["worktree", "list", "--porcelain"], repo_root)
    worktree_count = sum(1 for line in worktree_result.stdout.splitlines() if line.startswith("worktree "))
    if worktree_count != 1:
        fail("refusing to migrate a repository that already has linked worktrees")

    status_result = run_git(["status", "--porcelain", "--untracked-files=normal"], repo_root)
    status_lines = [line for line in status_result.stdout.splitlines() if line]
    meaningful_status_lines = [line for line in status_lines if not is_ds_store_status_line(line)]
    if meaningful_status_lines:
        fail("refusing to migrate with tracked or non-ignored untracked changes present")


def is_ds_store_path(path: Path) -> bool:
    return path.name == ".DS_Store"


def is_ds_store_status_line(line: str) -> bool:
    if not line.startswith("?? "):
        return False
    return is_ds_store_path(Path(line[3:]))


def stash_entries(repo_root: Path) -> list[StashEntry]:
    result = run_git(["stash", "list", "--format=%H%x1f%gs%x1e"], repo_root)
    entries: list[StashEntry] = []

    for record in result.stdout.split("\x1e"):
        record = record.strip()
        if not record:
            continue

        parts = record.split("\x1f", 1)
        if len(parts) != 2:
            warn(f"could not parse stash entry: {record}")
            continue

        oid, subject = parts
        branch = parse_stash_branch(subject)
        if not branch:
            warn(f"could not identify branch for stash entry: {subject}")
            continue
        if not branch_exists(repo_root, branch):
            warn(f"stash references missing local branch {branch}; no worktree will be created")
            continue

        entries.append(StashEntry(oid=oid, branch=branch, subject=subject))

    return entries


def stash_branches(entries: list[StashEntry], active_branch: str) -> list[str]:
    branches: list[str] = []

    for entry in entries:
        if entry.branch == active_branch or entry.branch in branches:
            continue
        branches.append(entry.branch)

    return branches


def ignored_root_files(repo_root: Path) -> tuple[list[Path], list[SkippedIgnoredEntry]]:
    result = run_git(["ls-files", "--others", "--ignored", "--exclude-standard", "-z"], repo_root)
    ignored: list[Path] = []
    skipped_items: dict[Path, list[Path]] = {}

    for raw_item in result.stdout.split("\0"):
        if not raw_item:
            continue

        relative_path = Path(raw_item)
        if is_ds_store_path(relative_path):
            continue

        full_path = repo_root / relative_path
        if relative_path.parent == Path(".") and full_path.is_file():
            ignored.append(relative_path)
        else:
            top_level = Path(relative_path.parts[0])
            skipped_items.setdefault(top_level, []).append(relative_path)

    skipped = [
        SkippedIgnoredEntry(path=path, items=sorted(items), is_dir=(repo_root / path).is_dir())
        for path, items in sorted(skipped_items.items())
    ]

    return sorted(ignored), skipped


def item_label(count: int) -> str:
    return "item" if count == 1 else "items"


def build_plan(cwd: Path, *, backup: bool) -> MigrationPlan:
    repo_root = repo_root_from_cwd(cwd)
    ensure_repo_can_migrate(repo_root)

    branch = current_branch(repo_root)
    entries = stash_entries(repo_root)
    extra_branches = stash_branches(entries, branch)
    ignored_files, skipped_ignored = ignored_root_files(repo_root)

    timestamp = datetime.now().strftime("%Y%m%d%H%M%S")
    staging_root = repo_root.parent / f".{repo_root.name}.worktree-migration-staging-{timestamp}"
    backup_zip = repo_root.parent / f".{repo_root.name}.pre-worktree-migration-{timestamp}.zip" if backup else None
    if staging_root.exists() or staging_root.is_symlink():
        fail(f"staging path already exists: {staging_root}")
    if backup_zip and (backup_zip.exists() or backup_zip.is_symlink()):
        fail(f"backup zip already exists: {backup_zip}")

    bare_root = repo_root / ".bare"
    shared_root = repo_root / "_shared"

    branch_worktrees = branch_worktree_paths(repo_root, [branch, *extra_branches])

    return MigrationPlan(
        repo_root=repo_root,
        staging_root=staging_root,
        backup_zip=backup_zip,
        bare_root=bare_root,
        shared_root=shared_root,
        current_branch=branch,
        branch_worktrees=branch_worktrees,
        stash_entries=entries,
        ignored_files=ignored_files,
        skipped_ignored=skipped_ignored,
    )


def print_plan(plan: MigrationPlan) -> None:
    info(f"repo: {plan.repo_root}")
    info(f"staging: {plan.staging_root}")
    if plan.backup_zip:
        info(f"backup zip: {plan.backup_zip}")
    else:
        info("backup zip: disabled")
    info(f"bare repo: {plan.bare_root}")
    info(f"shared files: {plan.shared_root}")

    for branch, worktree_path in plan.branch_worktrees.items():
        reason = "current branch" if branch == plan.current_branch else "branch with stash"
        info(f"worktree: {branch} -> {worktree_path} ({reason})")

    if plan.stash_entries:
        for entry in plan.stash_entries:
            info(f"stash found for {entry.branch}: {entry.subject}")
    else:
        info("no stash entries found")

    if plan.ignored_files:
        for ignored_file in plan.ignored_files:
            info(f"copy ignored file to _shared: {ignored_file}")
    else:
        info("no direct root-level ignored files found")

    for skipped_entry in plan.skipped_ignored:
        if skipped_entry.is_dir:
            warn(
                f"moving ignored directory into {plan.current_branch} worktree: "
                f"{skipped_entry.path}/ ({skipped_entry.item_count} {item_label(skipped_entry.item_count)})"
            )
        else:
            warn(
                f"moving ignored nested path into {plan.current_branch} worktree: "
                f"{skipped_entry.path} ({skipped_entry.item_count} {item_label(skipped_entry.item_count)})"
            )


def configure_bare_repo(bare_root: Path) -> None:
    run_git(["--git-dir", str(bare_root), "config", "core.bare", "true"], bare_root.parent)
    run_git(["--git-dir", str(bare_root), "config", "--unset", "core.worktree"], bare_root.parent, check=False)


def copy_ignored_files(plan: MigrationPlan) -> None:
    plan.shared_root.mkdir(parents=True, exist_ok=True)

    for relative_path in plan.ignored_files:
        source = plan.staging_root / relative_path
        target = plan.shared_root / relative_path.name
        if target.exists() or target.is_symlink():
            warn(f"{target.name} already exists in {plan.shared_root}, skipping {source}")
            continue
        shutil.copy2(source, target)
        info(f"copied {relative_path} -> {target}")


def link_shared_files(worktree_root: Path, shared_root: Path) -> None:
    if not shared_root.is_dir():
        return

    for source in sorted(shared_root.iterdir(), key=lambda path: path.name):
        if not source.is_file():
            continue

        target = worktree_root / source.name
        link_target = Path("..") / "_shared" / source.name
        link_target_text = link_target.as_posix()

        if target.is_symlink() and os.readlink(target) == link_target_text:
            continue

        if target.exists() or target.is_symlink():
            warn(f"{target.name} already exists in {worktree_root}, skipping {source}")
            continue

        target.symlink_to(link_target_text)
        info(f"linked {target.name} -> {link_target_text}")


def create_worktrees(plan: MigrationPlan) -> None:
    for branch, worktree_path in plan.branch_worktrees.items():
        run_command(
            ["git", "-c", "core.hooksPath=/dev/null", "--git-dir", str(plan.bare_root), "worktree", "add", "-q", str(worktree_path), branch],
            plan.repo_root,
        )
        link_shared_files(worktree_path, plan.shared_root)


def move_local_ignored_entries(plan: MigrationPlan) -> None:
    current_worktree = plan.branch_worktrees[plan.current_branch]

    for skipped_entry in plan.skipped_ignored:
        for relative_path in skipped_entry.items:
            source = plan.staging_root / relative_path
            target = current_worktree / relative_path

            if not source.exists() and not source.is_symlink():
                fail(f"expected ignored local file is missing from staging: {source}")
            if target.exists() or target.is_symlink():
                fail(f"refusing to overwrite existing path in current-branch worktree: {target}")

            target.parent.mkdir(parents=True, exist_ok=True)
            shutil.move(str(source), str(target))

    if plan.skipped_ignored:
        info(f"moved ignored local files into {plan.current_branch} worktree")


def apply_plan(plan: MigrationPlan) -> None:
    parent = plan.repo_root.parent
    os.chdir(parent)

    shutil.move(str(plan.repo_root), str(plan.staging_root))

    if plan.backup_zip:
        archive_base = plan.backup_zip.with_suffix("")
        shutil.make_archive(str(archive_base), "zip", root_dir=plan.staging_root)
        info(f"backup zip created: {plan.backup_zip}")

    plan.repo_root.mkdir()
    shutil.move(str(plan.staging_root / ".git"), str(plan.bare_root))

    configure_bare_repo(plan.bare_root)
    copy_ignored_files(plan)
    create_worktrees(plan)
    move_local_ignored_entries(plan)
    if plan.stash_entries:
        warn("stash entries were left untouched; apply them manually if needed")

    shutil.rmtree(plan.staging_root)

    info("migration complete")
    if plan.backup_zip:
        warn(f"original checkout preserved at {plan.backup_zip}")


def main(
    yes: Annotated[
        bool,
        typer.Option("--yes", help="Apply the migration. Without this flag, only print the plan."),
    ] = False,
    backup: Annotated[
        bool,
        typer.Option("--backup/--no-backup", help="Create a timestamped sibling zip of the original checkout."),
    ] = False,
) -> None:
    """Convert a normal Git checkout into a .bare + sibling worktree layout."""
    plan = build_plan(Path.cwd(), backup=backup)
    print_plan(plan)

    if not yes:
        warn("dry run only; re-run with --yes to apply this migration")
        return

    apply_plan(plan)


if __name__ == "__main__":
    typer.run(main)
